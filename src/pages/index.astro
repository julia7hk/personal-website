---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.JPG';
---

<Layout title="Julia Kang - CS & AI Student at Purdue">
	<section class="hero">
		<div class="container">
			<div class="hero-content">
				<div class="hero-text">
					<h1 class="hero-title animate-fade-in">
						Hi, I'm <a href="/about?animate=true" class="name-link"><span class="highlight typing-text"></span><span class="cursor">|</span></a>
					</h1>
					<p class="hero-subtitle animate-fade-in delay-1">
						Computer Science & AI Student at Purdue University
					</p>
					<p class="hero-description animate-fade-in delay-2">
						Interested in innovative solutions through full-stack development, machine learning, and biomedical research. Currently working on AI applications for echocardiograms and peptide database development.
					</p>
					<div class="hero-buttons animate-fade-in delay-3">
						<a href="/projects" class="btn btn-primary">View My Work</a>
						<a href="/contact" class="btn btn-secondary">Get In Touch</a>
					</div>
					<div class="hero-links animate-fade-in delay-4">
					<a href="https://github.com/julia7hk" target="_blank" class="social-link">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
						</svg>
					</a>
					<a href="https://linkedin.com/in/julia7hk" target="_blank" class="social-link">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
						</svg>
					</a>
					<a href="mailto:julia7hk@gmail.com" class="social-link">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-.904.732-1.636 1.636-1.636h1.909L12 11.64l8.455-7.819h1.909c.904 0 1.636.732 1.636 1.636z"/>
						</svg>
					</a>
				</div>
				</div>
				<div class="profile-image-wrapper animate-fade-in delay-2">
					<Image src={profileImage} alt="Julia Kang" class="profile-image" />
				</div>
			</div>
		</div>
	</section>

	<section class="skills-preview animate-slide-up">
		<div class="container">
			<div class="section-header">
				<h2 class="section-title">Technical Skills</h2>
			</div>
			<div class="skills-grid">
				<div class="skill-category">
					<h3>Languages</h3>
					<div class="skill-tags">
						<span class="skill-tag">Python</span>
						<span class="skill-tag">TypeScript</span>
						<span class="skill-tag">JavaScript</span>
						<span class="skill-tag">C</span>
						<span class="skill-tag">Java</span>
						<span class="skill-tag">SQL</span>
						<span class="skill-tag">HTML</span>
						<span class="skill-tag">CSS</span>
						<span class="skill-tag">R</span>
					</div>
				</div>
				<div class="skill-category">
					<h3>Web Frameworks/Libraries</h3>
					<div class="skill-tags">
						<span class="skill-tag">React</span>
						<span class="skill-tag">Next.js</span>
						<span class="skill-tag">TailwindCSS</span>
						<span class="skill-tag">Flask</span>
						<span class="skill-tag">FastAPI</span>
						<span class="skill-tag">Prisma</span>
						<span class="skill-tag">React Native</span>
					</div>
				</div>
				<div class="skill-category">
					<h3>AI Framework/Library</h3>
					<div class="skill-tags">
						<span class="skill-tag">PyTorch</span>
						<span class="skill-tag">TensorFlow</span>
						<span class="skill-tag">NumPy</span>
						<span class="skill-tag">Pandas</span>
						<span class="skill-tag">Matplotlib</span>
					</div>
				</div>
				<div class="skill-category">
					<h3>Databases</h3>
					<div class="skill-tags">
						<span class="skill-tag">Postgres</span>
						<span class="skill-tag">Supabase</span>
						<span class="skill-tag">Firebase</span>
						<span class="skill-tag">SQLite</span>
					</div>
				</div>
				<div class="skill-category">
					<h3>Cloud</h3>
					<div class="skill-tags">
						<span class="skill-tag">AWS</span>
						<span class="skill-tag">Google Compute Platform</span>
						<span class="skill-tag">Oracle Cloud</span>
						<span class="skill-tag">Netlify</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="featured-projects animate-slide-up">
		<div class="container">
			<div class="section-header">
				<h2 class="section-title">Featured Projects</h2>
				<a href="/projects" class="section-link">View All Projects &rarr;</a>
			</div>
			<div class="projects-preview-grid">
				<a href="/projects" class="project-preview-card">
					<div class="project-preview-header">
						<h3>Mead Johnson PeptideX</h3>
						<span class="project-preview-status">Current</span>
					</div>
					<p>Peptide database and web application for biomedical researchers, developed through The Data Mine corporate partnership.</p>
					<div class="project-preview-tech">
						<span>Python</span>
						<span>Next.js</span>
						<span>SQLite</span>
						<span>React</span>
					</div>
				</a>
				<a href="/projects" class="project-preview-card">
					<div class="project-preview-header">
						<h3>Aortic Root Dilation Research</h3>
						<span class="project-preview-status">Current</span>
					</div>
					<p>Predictive ML models for cardiovascular disease using echocardiogram data as a SURF Research Fellow at CVIRL.</p>
					<div class="project-preview-tech">
						<span>PyTorch</span>
						<span>Python</span>
						<span>AWS</span>
					</div>
				</a>
			</div>
		</div>
	</section>

</Layout>

<style>
	.hero {
		padding: 3rem 0 4rem;
		background: #fafaf8;
	}

	.container {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.hero-content {
		max-width: 900px;
		display: flex;
		align-items: flex-start;
		gap: 3rem;
	}

	.hero-text {
		flex: 1;
	}

	.profile-image-wrapper {
		width: 200px;
		height: 200px;
		border-radius: 50%;
		background: linear-gradient(0deg, #5372aa 0%, #141B29 100%);
		padding: 3px;
		flex-shrink: 0;
	}

	.profile-image {
		width: 100%;
		height: 100%;
		border-radius: 50%;
		object-fit: cover;
		display: block;
	}

	.hero-title {
		font-size: 2rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
		color: #2a2a2a;
		line-height: 1.4;
		letter-spacing: -0.02em;
	}

	.highlight {
		color: #5372aa;
		border-bottom: 2px solid #5372aa;
		transition: color 0.2s ease, border-color 0.2s ease;
	}

	.highlight:hover {
		color: #a9b4cd;
		border-bottom-color: #a9b4cd;
	}

	.hero-subtitle {
		font-size: 1rem;
		color: #6a6a6a;
		margin-bottom: 2rem;
		font-weight: 400;
	}

	.hero-description {
		font-size: 0.95rem;
		color: #4a4a4a;
		margin-bottom: 2.5rem;
		line-height: 1.7;
	}

	.hero-buttons {
		display: flex;
		gap: 1rem;
		margin-bottom: 2.5rem;
	}

	.btn {
		padding: 0.6rem 1.2rem;
		text-decoration: none;
		font-weight: 500;
		font-size: 0.9rem;
		transition: all 0.2s ease;
		display: inline-block;
		border: 1px solid #2a2a2a;
		border-radius: 4px;
	}

	.btn-primary {
		background: #5372aa;
		border-color: #5372aa;
		color: #fafaf8;
	}

	.btn-primary:hover {
		background: #a9b4cd;
		border-color: #a9b4cd;
	}

	.btn-secondary {
		background: transparent;
		border-color: #5372aa;
		color: #5372aa;
	}

	.btn-secondary:hover {
		background: #a9b4cd;
		border-color: #a9b4cd;
		color: #fafaf8;
	}

	.hero-links {
		display: flex;
		gap: 1.5rem;
	}

	.social-link {
		color: #a9b4cd;
		transition: color 0.2s ease;
	}

	.social-link:hover {
		color: #5372aa;
	}

	/* Stats Bar */
	.stats-bar {
		padding: 2rem 0;
		background: #fafaf8;
		border-top: 1px solid #e4e4e4;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
		text-align: center;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.stat-number {
		font-size: 1.75rem;
		font-weight: 700;
		color: #5372aa;
		letter-spacing: -0.02em;
	}

	.stat-label {
		font-size: 0.8rem;
		color: #6a6a6a;
		font-weight: 400;
	}

	/* Section Header */
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 2rem;
	}

	.section-title {
		font-size: 1.5rem;
		color: #2a2a2a;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	.section-link {
		font-size: 0.85rem;
		color: #5372aa;
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s ease;
	}

	.section-link:hover {
		color: #a9b4cd;
	}

	/* Skills */
	.skills-preview {
		padding: 3rem 0 4rem;
		background: #fafaf8;
		border-top: 1px solid #e4e4e4;
	}

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		max-width: 900px;
	}

	.skill-category h3 {
		font-size: 1rem;
		margin-bottom: 1rem;
		color: #2a2a2a;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.skill-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.skill-tag {
		background: transparent;
		color: #4a4a4a;
		padding: 0.4rem 0.8rem;
		border: 1px solid #d4d4d4;
		border-radius: 4px;
		font-size: 0.85rem;
		font-weight: 400;
		transition: all 0.2s ease;
	}

	.skill-tag:hover {
		border-color: #5372aa;
		color: #5372aa;
		transform: translateY(-1px);
	}

	/* Featured Projects */
	.featured-projects {
		padding: 3rem 0 4rem;
		background: #fafaf8;
		border-top: 1px solid #e4e4e4;
	}

	.projects-preview-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.5rem;
	}

	.project-preview-card {
		border: 1px solid #d4d4d4;
		border-radius: 6px;
		padding: 1.5rem;
		text-decoration: none;
		color: inherit;
		transition: all 0.2s ease;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.project-preview-card:hover {
		border-color: #5372aa;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(83, 114, 170, 0.08);
	}

	.project-preview-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 0.75rem;
	}

	.project-preview-header h3 {
		font-size: 1rem;
		font-weight: 600;
		color: #2a2a2a;
		letter-spacing: -0.01em;
	}

	.project-preview-status {
		font-size: 0.7rem;
		color: #5372aa;
		border: 1px solid #5372aa;
		padding: 0.15rem 0.5rem;
		border-radius: 3px;
		font-weight: 500;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.project-preview-card p {
		font-size: 0.85rem;
		color: #4a4a4a;
		line-height: 1.6;
		flex: 1;
	}

	.project-preview-tech {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.project-preview-tech span {
		font-size: 0.75rem;
		color: #6a6a6a;
		background: #f0f0ee;
		padding: 0.2rem 0.5rem;
		border-radius: 3px;
	}

	/* Experience Preview */
	.experience-preview {
		padding: 3rem 0 4rem;
		background: #fafaf8;
		border-top: 1px solid #e4e4e4;
	}

	.roles-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.role-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.25rem 0;
		border-bottom: 1px solid #e4e4e4;
		text-decoration: none;
		color: inherit;
		transition: all 0.2s ease;
	}

	.role-item:first-child {
		border-top: 1px solid #e4e4e4;
	}

	.role-item:hover {
		padding-left: 0.75rem;
	}

	.role-info {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.role-info h3 {
		font-size: 0.95rem;
		font-weight: 600;
		color: #2a2a2a;
		letter-spacing: -0.01em;
	}

	.role-org {
		font-size: 0.8rem;
		color: #6a6a6a;
	}

	.role-date {
		font-size: 0.8rem;
		color: #6a6a6a;
		white-space: nowrap;
		flex-shrink: 0;
	}

	/* CTA Section */
	.cta-section {
		padding: 4rem 0;
		background: #fafaf8;
		border-top: 1px solid #e4e4e4;
	}

	.cta-content {
		text-align: center;
		max-width: 500px;
		margin: 0 auto;
	}

	.cta-status {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
		font-size: 0.85rem;
		color: #5372aa;
		border: 1px solid #d4d4d4;
		padding: 0.4rem 1rem;
		border-radius: 20px;
	}

	.status-dot {
		width: 8px;
		height: 8px;
		background: #5372aa;
		border-radius: 50%;
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0%, 100% {
			opacity: 1;
		}
		50% {
			opacity: 0.4;
		}
	}

	.status-text {
		font-weight: 500;
	}

	.cta-title {
		font-size: 1.5rem;
		font-weight: 600;
		color: #2a2a2a;
		margin-bottom: 1rem;
		letter-spacing: -0.02em;
	}

	.cta-description {
		font-size: 0.9rem;
		color: #4a4a4a;
		margin-bottom: 2rem;
		line-height: 1.7;
	}

	.cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.hero {
			padding: 2rem 0 3rem;
		}

		.hero-content {
			flex-direction: column;
			gap: 0;
		}

		.profile-image-wrapper {
			display: none;
		}

		.hero-text {
			text-align: center;
		}

		.hero-title {
			font-size: 1.75rem;
		}

		.hero-subtitle {
			font-size: 0.95rem;
		}

		.hero-description {
			font-size: 0.9rem;
			margin-bottom: 2rem;
		}

		.hero-buttons {
			flex-direction: column;
			align-items: stretch;
			width: 100%;
			gap: 0.75rem;
		}

		.btn {
			width: 100%;
			text-align: center;
		}

		.hero-links {
			justify-content: center;
		}

		.stats-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1.5rem;
		}

		.stat-number {
			font-size: 1.5rem;
		}

		.skills-preview,
		.featured-projects,
		.experience-preview {
			padding: 2rem 0 3rem;
		}

		.section-header {
			flex-direction: column;
			gap: 0.5rem;
			margin-bottom: 1.5rem;
		}

		.section-title {
			font-size: 1.25rem;
		}

		.skills-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.projects-preview-grid {
			grid-template-columns: 1fr;
		}

		.role-item {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.25rem;
		}

		.cta-section {
			padding: 3rem 0;
		}

		.cta-buttons {
			flex-direction: column;
			align-items: stretch;
		}

		.cta-buttons .btn {
			width: 100%;
		}

		.container {
			padding: 0 1rem;
		}
	}

	/* Animations */
	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes slideUp {
		from {
			opacity: 0;
			transform: translateY(40px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes blink {
		0%, 50% {
			opacity: 1;
		}
		51%, 100% {
			opacity: 0;
		}
	}

	.animate-fade-in {
		opacity: 0;
		animation: fadeIn 0.4s ease-out forwards;
	}

	.animate-slide-up {
		opacity: 0;
		animation: slideUp 0.5s ease-out forwards;
		animation-delay: 0.5s;
	}

	.delay-1 {
		animation-delay: 0.1s;
	}

	.delay-2 {
		animation-delay: 0.2s;
	}

	.delay-3 {
		animation-delay: 0.3s;
	}

	.delay-4 {
		animation-delay: 0.4s;
	}

	.cursor {
		color: #5372aa;
		animation: blink 1s infinite;
		font-weight: 400;
	}

	.cursor.hidden {
		display: none;
	}

	.typing-text {
		border-bottom: 2px solid #5372aa;
	}

	.name-link {
		color: inherit;
		text-decoration: none;
	}

	.name-link:hover .typing-text {
		border-bottom-color: currentColor;
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const text = 'Julia Kang';
		const typingElement = document.querySelector('.typing-text');
		const cursor = document.querySelector('.cursor');
		let index = 0;

		function type() {
			if (index < text.length) {
				typingElement.textContent += text.charAt(index);
				index++;
				setTimeout(type, 80);
			} else {
				// Hide cursor after typing is complete
				setTimeout(() => {
					cursor?.classList.add('hidden');
				}, 1500);
			}
		}

		// Start typing after a brief delay
		setTimeout(type, 300);
	});
</script>
